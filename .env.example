# Deployment Configuration
# Copy this file to .env and fill in your values

# Database Configuration (PostgreSQL)
# For local development with Docker: pnpm db:local (matches docker-compose.local.yml)
# For production, use your PostgreSQL connection string (e.g., Koyeb managed database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/eduskript_dev"

# PostgreSQL Configuration (for worktree-safe development)
# These are auto-generated by pnpm setup, but you can override them:
# POSTGRES_PORT=5432
# POSTGRES_CONTAINER_NAME=eduskript-postgres-dev
# POSTGRES_VOLUME_NAME=postgres_data

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Next.js Port (auto-generated by pnpm setup for worktree-safe development)
# PORT=3000

# Default organization slug - all unknown domains fall back to this org
# DEFAULT_ORG_SLUG=eduskript

# OAuth Providers (Optional - remove CLIENT_ID or CLIENT_SECRET to disable)
# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft (Azure AD) OAuth
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Student Pseudonym Generation (Generate a secure random string for production)
STUDENT_PSEUDONYM_SECRET=change-this-to-a-random-secret-in-production

# File Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,svg,pdf,doc,docx,txt,md,zip,mp4,mp3,wav,excalidraw

# Email Configuration (Brevo)
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME="Your App Name"

# Deployment
# VPS hostname (required for deployment)
DEPLOY_VPS_HOST=your-vps-hostname.com

# VPS SSH username (required for deployment)
DEPLOY_VPS_USER=your-ssh-username

# Optional: Override repository (defaults to marcchehab/eduskript)
# DEPLOY_REPO=marcchehab/eduskript

# Optional: Override Docker image (defaults to ghcr.io/marcchehab/eduskript:latest)
# DEPLOY_IMAGE=ghcr.io/marcchehab/eduskript:latest

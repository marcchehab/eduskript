// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Start from scratch? 
// pnpm prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql
// pnpm prisma migrate resolve --applied 0_init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int? // Microsoft-specific: extended token expiration
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique // Optional for students (OAuth-only)
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Profile fields (shown to collaborators).
  // Public-page display fields (pageName, pageDescription, pageIcon,
  // pageTagline, pageLanguage, sidebarBehavior, typographyPreference,
  // aiSystemPrompt) all live on Site now — Site is the only public-page
  // entity, and the duplicates made every write path a footgun.
  bio   String?
  title String?

  // User preferences (per-user, not per-site)
  themePreference String? @default("system") // "light", "dark", or "system"

  // Admin and security
  isAdmin                Boolean @default(false)
  requirePasswordReset   Boolean @default(false)
  needsProfileCompletion Boolean @default(false) // True for new OAuth teachers until they complete their profile

  // Privacy and account type
  accountType      String    @default("teacher") // "teacher" or "student"
  studentPseudonym String?   @unique // For student privacy: hash(oauthProvider:oauthProviderId) for OAuth, hash(email) for legacy
  // Throwaway email+password student account a teacher creates for a spare laptop
  // during an exam (device crash). Flagged so the toolbar can offer "Transfer
  // answers" to the student's real account afterwards. See exam-recovery / transfer route.
  isTemporary      Boolean   @default(false) @map("is_temporary")
  gdprConsentAt    DateTime? // Timestamp of GDPR consent acceptance
  lastSeenAt       DateTime? // For inactive account cleanup

  // OAuth identification (for students - replaces email storage)
  oauthProvider   String? // "github", "google", "microsoft", "azure-ad"
  oauthProviderId String? // Provider's unique user ID

  // Relations
  accounts     Account[]
  sessions     Session[]
  pageVersions PageVersion[]

  // Many-to-many relations for content authoring (skripts/pages stay
  // multi-author across users; collections are owned 1:1 by a Site).
  skriptAuthors SkriptAuthor[]
  pageAuthors   PageAuthor[]

  // File uploads
  files File[]

  // Collaboration relations
  sentCollaborationRequests     CollaborationRequest[] @relation("SentRequests")
  receivedCollaborationRequests CollaborationRequest[] @relation("ReceivedRequests")
  collaborationsAsRequester     Collaboration[]        @relation("RequesterCollaborations")
  collaborationsAsReceiver      Collaboration[]        @relation("ReceiverCollaborations")

  // The user's public site (1:1). Owns the URL slug, page-display fields,
  // collections, page layout, and frontpage. Teachers get a Site; students
  // typically don't.
  site Site?

  // Student data
  studentProgress    StudentProgress[]   @relation("StudentProgress")
  studentSubmissions StudentSubmission[] @relation("StudentSubmissions")

  // Class relations
  teacherClasses     Class[]           @relation("TeacherClasses")
  studentMemberships ClassMembership[] @relation("StudentMemberships")

  // Exam unlock relations
  studentUnlocks PageUnlock[] @relation("StudentUnlocks") // Pages unlocked for this student
  teacherUnlocks PageUnlock[] @relation("TeacherUnlocks") // Pages this teacher has unlocked

  // User data (code, annotations, settings, etc.)
  userData UserData[] @relation("UserDataEntries")

  // Server-side checkpoints — explicit snapshots written on manual save,
  // "Check" press, and exam hand-in (see UserDataCheckpoint).
  userDataCheckpoints UserDataCheckpoint[] @relation("UserCheckpoints")

  // Front page versions authored by this user. Site-level frontpages live
  // on Site, not on User, so no User.frontPage reverse relation.
  frontPageVersions FrontPageVersion[]

  // Import/Export jobs
  importJobs ImportJob[]

  // Organization memberships
  organizationMemberships OrganizationMember[]

  // Custom domains for teachers
  customDomains TeacherCustomDomain[]

  // Billing
  billingPlan   String         @default("free") @map("billing_plan") // "free" | "pro" | etc.
  subscriptions Subscription[]

  // Last successful sign-in (updated in NextAuth signIn callback)
  lastLoginAt DateTime? @map("last_login_at")

  // SEB exam tokens and sessions
  examTokens   ExamToken[]   @relation("ExamTokens")
  examSessions ExamSession[] @relation("ExamSessions")

  // MCP OAuth (per-teacher scoped API access for claude.ai / Claude Code / Cursor)
  oauthAuthorizationCodes OAuthAuthorizationCode[] @relation("OAuthAuthorizationCodes")
  oauthAccessTokens       OAuthAccessToken[]       @relation("OAuthAccessTokens")
  oauthRefreshTokens      OAuthRefreshToken[]      @relation("OAuthRefreshTokens")

  // Exam submissions (student). Scoring/return state lives in ExamAuditLog now;
  // scoredExamSubmissions is a dead back-relation kept until the contract migration.
  examSubmissions       ExamSubmission[] @relation("StudentExamSubmissions")
  scoredExamSubmissions ExamSubmission[] @relation("ScoredExamSubmissions")
  // Per-student exam-state overrides (makeups / accommodations)
  examStates            ExamState[]      @relation("StudentExamStates")

  // Append-only event log for exam attempts (started / submitted / reopened) plus
  // grading events (return / take_back). Source of truth for "currently returned".
  examAuditLogs      ExamAuditLog[] @relation("StudentExamAuditLogs")
  // Grading events (return / take_back) this user performed as the teacher actor.
  actedExamAuditLogs ExamAuditLog[] @relation("ActorExamAuditLogs")
  // Per-question score sources (check / ai / override), priority-resolved.
  componentScores ComponentScore[] @relation("StudentComponentScores")

  // Encryption keys used by students to encrypt offline exam backups.
  // Rotatable; old keys are kept so historical .examfile backups stay decryptable.
  examKeys TeacherExamKey[] @relation("TeacherExamKeys")

  // Cross-domain auth tokens
  crossDomainTokens CrossDomainToken[]

  // Uploaded videos
  uploadedVideos Video[] @relation("UploadedVideos")

  // Plugins
  plugins Plugin[]

  // Pages forked from this user's content
  forkedPages Page[] @relation("ForkedPages")

  @@unique([oauthProvider, oauthProviderId]) // Students identified by OAuth provider
  @@map("users")
}

// A public page/site. Owned polymorphically by either a User (a teacher's
// personal page) or an Organization (a school/group page) — exactly one of
// userId / organizationId is set. The polymorphism lives here, in one model,
// so downstream tables (Collection, PageLayout, FrontPage) reference a single
// siteId instead of inventing their own userId|organizationId pair. The URL
// slug and every page-display setting also live here.
model Site {
  id   String @id @default(cuid())
  slug String @unique // Globally unique URL slug for the public page

  userId         String? @unique @map("user_id")
  organizationId String? @unique @map("organization_id")

  // Page-display fields
  pageName             String? @map("page_name")
  pageDescription      String? @map("page_description")
  pageIcon             String? @map("page_icon")
  pageTagline          String? @map("page_tagline")
  pageLanguage         String? @map("page_language") // BCP-47, null = "en"
  sidebarBehavior      String  @default("full") @map("sidebar_behavior") // "full" | "contextual"
  typographyPreference String? @default("modern") @map("typography_preference")
  showIcon             Boolean @default(true) @map("show_icon")
  aiSystemPrompt       String? @map("ai_system_prompt") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  collections Collection[]
  pageLayout  PageLayout?
  frontPage   FrontPage?

  @@map("sites")
}

model Collection {
  id          String   @id @default(cuid())
  // Owning site. A collection is just a sidebar grouping on a single site;
  // there's no longer a per-collection author table — site ownership is the
  // single source of truth.
  siteId      String   @map("site_id")
  title       String
  accentColor String? // Hex color for sidebar letter markers (e.g., "#3b82f6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  collectionSkripts CollectionSkript[]

  @@index([siteId])
  @@map("collections")
}

// Junction table for Collection-Skript many-to-many relationship. Pure
// linkage between a collection and the skripts it contains; ordering lives
// on this row. Root skripts live in PageLayout.items, not here.
//
// Existing columns keep their camelCase names (collectionId, skriptId,
// createdAt) so the Prisma migration is purely structural — no column
// renames — to avoid the drop+add behaviour that would lose data.
model CollectionSkript {
  id           String   @id @default(cuid())
  collectionId String
  skriptId     String
  order        Int
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  skript     Skript     @relation(fields: [skriptId], references: [id], onDelete: Cascade)

  @@unique([collectionId, skriptId])
  @@map("collection_skripts")
}

model Skript {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String
  isPublished Boolean  @default(false)
  isUnlisted  Boolean  @default(false)
  skriptType  String   @default("normal") @map("skript_type") // "normal", "randomized-daily", "randomized-weekly"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  collectionSkripts CollectionSkript[]
  pages             Page[]

  // Many-to-many relation for multiple authors
  authors SkriptAuthor[]

  // Files associated with this skript
  files File[]

  // Videos associated with this skript (many-to-many)
  videos Video[] @relation("SkriptVideos")

  // Front page (intro/landing page for skript)
  frontPage FrontPage?

  // File storage for user/org FrontPages (reverse relation)
  frontPageFileStorage FrontPage? @relation("FrontPageFileStorage")

  // SEB exam sessions
  examSessions ExamSession[] @relation("ExamSessionSkript")

  @@index([slug])
  @@map("skripts")
}

// Junction table for Skript-User many-to-many relationship
model SkriptAuthor {
  id         String   @id @default(cuid())
  skriptId   String
  userId     String
  permission String   @default("author") // "author" (can edit & manage), "viewer" (can only view)
  createdAt  DateTime @default(now())

  skript Skript @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skriptId, userId])
  @@map("skript_authors")
}

model Page {
  id           String   @id @default(cuid())
  title        String
  slug         String
  content      String
  // Optional teacher-authored summary. When set, used as the og:description
  // ahead of the auto-derived generateExcerpt(content) fallback so social
  // previews surface the teacher's intent rather than the first prose
  // paragraph.
  description  String?
  order        Int
  isPublished  Boolean  @default(false)
  isUnlisted   Boolean  @default(false)
  pageType     String   @default("normal") @map("page_type") // "normal", "exam"
  examSettings Json?    @map("exam_settings") // { requireSEB: boolean, timeLimitMinutes?: number }
  // When true the "Present as slides" button is shown to everyone, not just
  // logged-in teachers. Off by default — presenting is a teacher action.
  presentationPublic Boolean @default(false) @map("presentation_public")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Provenance (fork tracking)
  forkedFromPageId   String?   @map("forked_from_page_id")
  forkedFromAuthorId String?   @map("forked_from_author_id")
  forkedAt           DateTime? @map("forked_at")

  // Relations
  skriptId String
  skript   Skript        @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  versions PageVersion[]

  // Fork relations
  forkedFromPage   Page?  @relation("PageForks", fields: [forkedFromPageId], references: [id], onDelete: SetNull)
  forks            Page[] @relation("PageForks")
  forkedFromAuthor User?  @relation("ForkedPages", fields: [forkedFromAuthorId], references: [id], onDelete: SetNull)

  // Many-to-many relation for multiple authors
  authors PageAuthor[]

  // Student data
  studentProgress    StudentProgress[]   @relation("PageProgress")
  studentSubmissions StudentSubmission[] @relation("PageSubmissions")

  // Exam unlocks
  unlocks PageUnlock[]

  // SEB exam tokens and sessions
  examTokens   ExamToken[]   @relation("ExamTokens")
  examSessions ExamSession[] @relation("ExamSessionPage")

  // Exam state and submissions
  examStates         ExamState[]         @relation("ExamStates")
  examSubmissions    ExamSubmission[]    @relation("ExamSubmissions")
  examAuditLogs      ExamAuditLog[]      @relation("PageExamAuditLogs")
  examGradeConfig    ExamGradeConfig?    @relation("ExamGradeConfigs")
  componentScores    ComponentScore[]    @relation("ComponentScores")
  scoringRubrics     ScoringRubric[]     @relation("ScoringRubrics")

  // Server-side checkpoints captured at manual save / Check / hand-in
  userDataCheckpoints UserDataCheckpoint[] @relation("PageCheckpoints")

  // Implicit survey class (if this page has a <Survey>, an anonymous-allowed
  // class is auto-created on first response submission and bound here).
  implicitSurveyClass Class? @relation("ImplicitSurveyClass")

  @@unique([skriptId, slug])
  @@map("pages")
}

// Junction table for Page-User many-to-many relationship
model PageAuthor {
  id         String   @id @default(cuid())
  pageId     String
  userId     String
  permission String   @default("author") // "author" (can edit & manage), "viewer" (can only view)
  createdAt  DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@map("page_authors")
}

model PageVersion {
  id         String   @id @default(cuid())
  content    String
  version    Int
  changeLog  String?
  authorId   String
  pageId     String
  // Attribution for AI-assisted edits — null = direct dashboard edit.
  // editSource is "mcp" (claude.ai / Cursor / Claude Code via /api/mcp) or "ai-edit"
  // (in-product AI Edit feature). editClient snapshots OAuthClient.name when source=mcp.
  editSource String?  @map("edit_source")
  editClient String?  @map("edit_client")
  createdAt  DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  page   Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
  @@map("page_versions")
}

model File {
  id          String   @id @default(cuid())
  name        String
  parentId    String?  @map("parent_id")
  isDirectory Boolean  @default(false) @map("is_directory")
  skriptId    String   @map("skript_id")
  hash        String?
  contentType String?  @map("content_type")
  size        BigInt?
  width       Int? // Image width in pixels (null for non-image files)
  height      Int? // Image height in pixels (null for non-image files)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  parent   File?  @relation("FileParent", fields: [parentId], references: [id], onDelete: Cascade)
  children File[] @relation("FileParent")
  skript   Skript @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  creator  User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([parentId, name, skriptId], name: "unique_file_name_per_parent_skript")
  @@index([parentId, skriptId], name: "parent_skript_idx")
  @@index([hash], name: "hash_idx")
  @@map("files")
}

// Video storage for hosted video files (Mux, etc.)
// Uses JSONB for provider-specific metadata (flexible for future providers)
model Video {
  id           String  @id @default(cuid())
  filename     String // e.g., "lecture.mp4"
  provider     String  @default("mux") // "mux", future: "bunny", "cloudflare"
  metadata     Json // Provider-specific: { playbackId, poster, blurDataURL, aspectRatio, status }
  uploadedById String? @map("uploaded_by_id")
  muxUploadId  String? @unique @map("mux_upload_id") // For webhook lookup after direct upload
  muxAssetId   String? @unique @map("mux_asset_id") // For webhook lookup when asset ready

  uploadedBy User?    @relation("UploadedVideos", fields: [uploadedById], references: [id], onDelete: SetNull)
  skripts    Skript[] @relation("SkriptVideos") // Many-to-many

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([filename, provider, uploadedById])
  @@index([filename])
  @@index([uploadedById])
  @@map("videos")
}

// Collaboration request model for pending requests
model CollaborationRequest {
  id          String   @id @default(cuid())
  requesterId String   @map("requester_id")
  receiverId  String   @map("receiver_id")
  message     String? // Optional message from requester
  status      String   @default("pending") // "pending", "accepted", "rejected"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@map("collaboration_requests")
}

// Collaboration model for accepted partnerships
model Collaboration {
  id          String   @id @default(cuid())
  requesterId String   @map("requester_id") // User who sent the original request
  receiverId  String   @map("receiver_id") // User who accepted the request
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  requester User @relation("RequesterCollaborations", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceiverCollaborations", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@map("collaborations")
}

// Page layout for user's public page
model PageLayout {
  id        String           @id @default(cuid())
  // Single unified layout table keyed on Site. User-page and org-page
  // layouts both live here; the polymorphism is handled by Site.
  siteId    String           @unique @map("site_id")
  items     PageLayoutItem[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("page_layouts")
}

// Individual items in a page layout
model PageLayoutItem {
  id           String   @id @default(cuid())
  pageLayoutId String   @map("page_layout_id")
  type         String // "collection" or "skript"
  contentId    String   @map("content_id") // ID of the collection or skript
  order        Int
  createdAt    DateTime @default(now()) @map("created_at")

  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@unique([pageLayoutId, contentId, type])
  @@map("page_layout_items")
}

// Student Progress Tracking
// Tracks which pages students have viewed and completed
model StudentProgress {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  pageId       String   @map("page_id")
  completed    Boolean  @default(false)
  lastViewedAt DateTime @default(now()) @map("last_viewed_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student User @relation("StudentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  page    Page @relation("PageProgress", fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([studentId, pageId])
  @@index([studentId])
  @@index([pageId])
  @@map("student_progress")
}

// Student Submissions
// Stores student work like annotations, code, or text submissions
model StudentSubmission {
  id          String   @id @default(cuid())
  studentId   String   @map("student_id")
  pageId      String   @map("page_id")
  contentData String   @map("content_data") // JSON stringified data (annotations, code, etc.)
  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  grade       Float? // Optional numeric grade
  feedback    String? // Optional teacher feedback

  student User @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  page    Page @relation("PageSubmissions", fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([studentId, pageId])
  @@index([studentId])
  @@index([pageId])
  @@map("student_submissions")
}

// Class model - teacher-owned groups of students.
// Implicit classes (isImplicit=true) are auto-created per survey-page to enumerate
// anonymous respondents; they have no teacher (teacherId is null) and are bound to
// a specific page via implicitPageId. Auth for viewing their data routes through
// PageAuthor inheritance (checkPagePermissions), not class ownership.
model Class {
  id             String   @id @default(cuid())
  name           String
  description    String?
  teacherId      String?  @map("teacher_id") // Nullable: implicit survey classes have no owner
  inviteCode     String   @unique @map("invite_code")
  isActive       Boolean  @default(true) @map("is_active")
  allowAnonymous Boolean  @default(false) @map("allow_anonymous")
  // Anti-distraction (NOT security): when true, logged-in members must use Safe
  // Exam Browser to view the teacher's site. Enforced client-side via middleware
  // gate (src/proxy.ts → /api/internal/check-lockdown). Anonymous visitors bypass.
  lockdownMode   Boolean  @default(false) @map("lockdown_mode")
  isImplicit     Boolean  @default(false) @map("is_implicit") // True for auto-generated survey/pseudo classes
  implicitPageId String?  @unique @map("implicit_page_id") // For isImplicit=true: the page this class is bound to
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  teacher               User?                  @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  implicitPage          Page?                  @relation("ImplicitSurveyClass", fields: [implicitPageId], references: [id], onDelete: Cascade)
  memberships           ClassMembership[]
  preAuthorizedStudents PreAuthorizedStudent[]
  pageUnlocks           PageUnlock[]           @relation("ClassUnlocks") // Pages unlocked for this class
  examStates            ExamState[]            @relation("ClassExamStates") // Exam states per class

  @@index([teacherId])
  @@index([inviteCode])
  @@index([isImplicit])
  @@map("classes")
}

// Junction table for Class-Student many-to-many
model ClassMembership {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Privacy: Student consent for teacher to see their real identity
  identityConsent Boolean   @default(false) @map("identity_consent")
  consentedAt     DateTime? @map("consented_at")

  // Relations
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("StudentMemberships", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@map("class_memberships")
}

// Pre-authorized student pseudonyms (for bulk import)
model PreAuthorizedStudent {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  pseudonym String // Hashed email (before student signs up)
  addedAt   DateTime @default(now()) @map("added_at")

  // Relations
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, pseudonym])
  @@index([pseudonym])
  @@index([classId])
  @@map("pre_authorized_students")
}

// Exam page unlocks - can unlock for entire class OR individual student
model PageUnlock {
  id         String   @id @default(cuid())
  pageId     String   @map("page_id")
  classId    String?  @map("class_id") // Unlock for entire class (optional)
  studentId  String?  @map("student_id") // OR unlock for individual student (optional)
  unlockedBy String   @map("unlocked_by")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  // Relations
  page    Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  class   Class? @relation("ClassUnlocks", fields: [classId], references: [id], onDelete: Cascade)
  student User?  @relation("StudentUnlocks", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User   @relation("TeacherUnlocks", fields: [unlockedBy], references: [id])

  @@unique([pageId, classId]) // One unlock per page per class
  @@unique([pageId, studentId]) // One unlock per page per student
  @@index([classId])
  @@index([studentId])
  @@index([pageId])
  @@map("page_unlocks")
}

// User Data Storage
// Stores all user-generated data (code, annotations, settings) with cloud sync support
// Uses JSONB for flexible, queryable storage with efficient updates
// Supports teacher broadcasts: targetType='class' for class-wide, 'student' for individual feedback
model UserData {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  adapter   String // Data type: 'code', 'annotations', 'settings', 'preferences', 'snaps'
  itemId    String   @map("item_id") // pageId for page-specific data, 'global' for user-wide data
  data      Json // JSONB - the actual data payload
  version   Int      @default(1) // Optimistic concurrency control
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Targeting for teacher broadcasts and feedback
  // null = personal data, 'class' = broadcast to class, 'student' = individual feedback
  targetType String? @map("target_type")
  targetId   String? @map("target_id") // classId when targetType='class', studentId when targetType='student'

  // Relations
  user User @relation("UserDataEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, adapter, itemId, targetType, targetId])
  @@index([userId])
  @@index([userId, adapter])
  @@index([updatedAt])
  @@index([targetType, targetId, adapter, itemId]) // For querying broadcasts/feedback
  @@map("user_data")
}

// Server-side snapshots of student work captured on explicit events.
// Four event kinds: 'manual' (Save button), 'check' (Python check / SQL
// verification), 'run' (Run button — deduped client-side so identical
// consecutive runs collapse), 'handin' (exam hand-in). Bounded volume
// because all four are user-initiated; this is NOT a keystroke-level
// autosave log. Used for the teacher checkpoint timeline and exam grading.
model UserDataCheckpoint {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  pageId      String   @map("page_id")
  componentId String   @map("component_id") // e.g. "code-editor-abc123"
  kind        String // 'manual' | 'check' | 'run' | 'handin'
  payload     Json // Snapshot data (e.g. CodeEditorData)
  label       String? // Optional label for manual saves
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation("UserCheckpoints", fields: [userId], references: [id], onDelete: Cascade)
  page Page @relation("PageCheckpoints", fields: [pageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pageId])
  @@index([userId, pageId, componentId, createdAt])
  @@map("user_data_checkpoints")
}

// FrontPage model - custom landing pages for users, skripts, and organizations
// Supports versioning and draft mode (isPublished)
model FrontPage {
  id          String   @id @default(cuid())
  content     String   @default("")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Owner. Exactly one of {siteId, skriptId} is set. Site-level frontpages
  // (user / org page landing) live under siteId; skript frontpages still
  // attach directly to a Skript.
  siteId   String? @unique @map("site_id")
  skriptId String? @unique @map("skript_id")

  // File storage for site-level FrontPages (skript FrontPages use their skript's files)
  fileSkriptId String? @unique @map("file_skript_id")

  // Relations
  site       Site?              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  skript     Skript?            @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  fileSkript Skript?            @relation("FrontPageFileStorage", fields: [fileSkriptId], references: [id])
  versions   FrontPageVersion[]

  @@map("front_pages")
}

// Version history for front pages
model FrontPageVersion {
  id          String   @id @default(cuid())
  content     String
  version     Int
  changeLog   String?  @map("change_log")
  authorId    String   @map("author_id")
  frontPageId String   @map("front_page_id")
  createdAt   DateTime @default(now()) @map("created_at")

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  frontPage FrontPage @relation(fields: [frontPageId], references: [id], onDelete: Cascade)

  @@unique([frontPageId, version])
  @@map("front_page_versions")
}

// Import/Export Job Tracking
// Tracks large file import/export operations with progress and one-per-user limit
model ImportJob {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  type     String // "import" or "export"
  status   String  @default("pending") // "pending", "uploading", "processing", "completed", "failed", "cancelled"
  progress Int     @default(0) // 0-100
  message  String? // Current status message for UI

  // File info
  s3Key    String? @map("s3_key") // S3 key for uploaded/exported file
  fileName String? @map("file_name") // Original filename
  fileSize BigInt? @map("file_size") // Size in bytes

  // Results
  result Json? // Import: { skriptsCreated, pagesCreated, filesImported }, Export: { downloadUrl }
  error  String? // Error message if failed

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@map("import_jobs")
}

// Organization model - schools, companies, or groups. Holds entity, display,
// and governance fields. URL slug lives on the org's Site; display fields
// will move next (Stage 5b).
model Organization {
  id   String @id @default(cuid())
  name String // "Eduskript", "Springfield High" — entity name
  // Page-display fields (description, showIcon, iconUrl, pageLanguage,
  // pageTagline, sidebarBehavior, aiSystemPrompt) all live on Site now —
  // Site is the only public-page entity.

  // Settings (entity-level, not page-level)
  allowMemberPages          Boolean @default(true) @map("allow_member_pages")
  allowTeacherCustomDomains Boolean @default(false) @map("allow_teacher_custom_domains")
  requireEmailDomain        String? @map("require_email_domain")

  // Billing groundwork (payment provider TBD)
  billingPlan String @default("free") @map("billing_plan")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  members       OrganizationMember[]
  customDomains CustomDomain[]

  // The org's public site (1:1). Owns the URL slug, page layout, collections,
  // frontpage. Display fields move here in a follow-up.
  site Site?

  @@map("organizations")
}

// Junction table for Organization-User many-to-many
model OrganizationMember {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  role           String @default("member") // "owner" | "admin" | "member"

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

// Custom domain mapping for organizations
// Allows orgs to use their own domains (e.g., eduskript.org, school.edu)
model CustomDomain {
  id                String    @id @default(cuid())
  domain            String    @unique // "eduskript.org", "school.edu"
  organizationId    String    @map("organization_id")
  isPrimary         Boolean   @default(false) @map("is_primary")
  isVerified        Boolean   @default(false) @map("is_verified")
  verificationToken String?   @map("verification_token")
  verifiedAt        DateTime? @map("verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([organizationId])
  @@map("custom_domains")
}

// Custom domain mapping for teachers
// Allows teachers to use their own domains (e.g., mr-smith.com)
model TeacherCustomDomain {
  id                String    @id @default(cuid())
  domain            String    @unique // "mr-smith.com", "teacher.school.edu"
  userId            String    @map("user_id")
  isPrimary         Boolean   @default(false) @map("is_primary")
  isVerified        Boolean   @default(false) @map("is_verified")
  verificationToken String?   @map("verification_token")
  verifiedAt        DateTime? @map("verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([userId])
  @@map("teacher_custom_domains")
}

// One-time tokens for SEB exam authentication
// When a logged-in user opens SEB, a token is generated and embedded in the startURL
// SEB navigates to the URL with the token, which authenticates the user without re-login
model ExamToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash") // SHA256 hash of plaintext token
  userId    String    @map("user_id")
  pageId    String    @map("page_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // Set when token is consumed (one-time use)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation("ExamTokens", fields: [userId], references: [id], onDelete: Cascade)
  page Page @relation("ExamTokens", fields: [pageId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@index([pageId])
  @@map("exam_tokens")
}

// MCP OAuth: registered third-party clients (claude.ai, Claude Code, Cursor, etc.)
// Created via RFC 7591 Dynamic Client Registration on /api/mcp/oauth/register
// Public PKCE-only clients have null clientSecretHash; redirect_uris is the allowlist enforced at /authorize
model OAuthClient {
  id                 String   @id @default(cuid())
  clientId           String   @unique @map("client_id")
  clientSecretHash   String?  @map("client_secret_hash") // null for public PKCE-only clients
  name               String
  redirectUris       String[] @map("redirect_uris")
  grantTypes         String[] @default(["authorization_code", "refresh_token"]) @map("grant_types")
  scopes             String[] @default(["content:read", "content:write"])
  registeredByUserId String?  @map("registered_by_user_id") // null for DCR-registered clients
  createdAt          DateTime @default(now()) @map("created_at")

  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  @@index([clientId])
  @@map("oauth_clients")
}

// MCP OAuth: short-lived authorization codes (10 min expiry, single-use via usedAt)
model OAuthAuthorizationCode {
  id                  String    @id @default(cuid())
  codeHash            String    @unique @map("code_hash")
  clientId            String    @map("client_id")
  userId              String    @map("user_id")
  redirectUri         String    @map("redirect_uri")
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @map("code_challenge_method") // "S256"
  scopes              String[]
  expiresAt           DateTime  @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation("OAuthAuthorizationCodes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([codeHash])
  @@map("oauth_authorization_codes")
}

// MCP OAuth: bearer access tokens (1h expiry; revocation via revokedAt)
model OAuthAccessToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix") // first 12 chars of plaintext, for UI display only
  clientId    String    @map("client_id")
  userId      String    @map("user_id")
  scopes      String[]
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation("OAuthAccessTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("oauth_access_tokens")
}

// MCP OAuth: refresh tokens (30d expiry, rotate on use; replacedById tracks the rotation chain for audit)
model OAuthRefreshToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique @map("token_hash")
  clientId     String    @map("client_id")
  userId       String    @map("user_id")
  scopes       String[]
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation("OAuthRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("oauth_refresh_tokens")
}

// Exam sessions for multi-page SEB exams
// After token auth, an exam session is created to persist auth across page navigations
// Session allows access to all pages within the same skript during the exam
model ExamSession {
  id        String   @id @default(cuid())
  sessionId String   @unique @map("session_id") // Random ID stored in cookie
  userId    String   @map("user_id")
  pageId    String   @map("page_id") // Initial exam page that started session
  skriptId  String   @map("skript_id") // Allow access to all pages in this skript
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation("ExamSessions", fields: [userId], references: [id], onDelete: Cascade)
  page   Page   @relation("ExamSessionPage", fields: [pageId], references: [id], onDelete: Cascade)
  skript Skript @relation("ExamSessionSkript", fields: [skriptId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([skriptId])
  @@map("exam_sessions")
}

// Per-class (and optionally per-student) exam lifecycle — the SINGLE source of
// truth for exam assignment + timing. A row's existence == "assigned" (visible);
// `state` controls entry. No row for a (page, class[, student]) == hidden.
//   class row:   studentId = null  → applies to the whole class
//   student row: studentId set     → overrides the class row for that one student
// Effective state for a student = student row ?? class row ?? hidden.
// Replaces the old PageUnlock(class) + separate ExamState split.
// States:
//   "hidden" - Not assigned: not in the class sidebar, cannot enter
//   "closed" - Assigned/visible, but cannot enter yet
//   "lobby"  - Can enter, sees waiting room until teacher opens
//   "open"   - Can take the exam
// Teachers can freely switch between any state at any time.
model ExamState {
  id        String    @id @default(cuid())
  pageId    String    @map("page_id")
  classId   String    @map("class_id")
  studentId String?   @map("student_id") // null = class-level row; set = per-student override
  state     String    @default("closed") // "hidden" | "closed" | "lobby" | "open"
  openedAt  DateTime? @map("opened_at")
  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  page    Page  @relation("ExamStates", fields: [pageId], references: [id], onDelete: Cascade)
  class   Class @relation("ClassExamStates", fields: [classId], references: [id], onDelete: Cascade)
  student User? @relation("StudentExamStates", fields: [studentId], references: [id], onDelete: Cascade)

  // Uniqueness with a nullable studentId needs NULLS NOT DISTINCT so the
  // class-level row (studentId = null) stays unique per (page, class). Prisma
  // can't express that in-schema, so the generated migration is hand-edited to
  // add `NULLS NOT DISTINCT` to this unique index (see the migration SQL).
  @@unique([pageId, classId, studentId])
  @@index([pageId])
  @@index([classId])
  @@index([studentId])
  @@map("exam_states")
}

// Exam submission tracking - records when students hand in
model ExamSubmission {
  id          String   @id @default(cuid())
  pageId      String   @map("page_id")
  studentId   String   @map("student_id")
  submittedAt DateTime @default(now()) @map("submitted_at")
  // How the submission was created. Open-ended (like ComponentScore.source) so a
  // new origin doesn't need a schema change:
  //   "student"  — the student handed in (default)
  //   "teacher"  — the teacher ended it on the student's behalf (crashed machine)
  //   "recovery" — imported via offline/crash recovery
  //   <future>   — e.g. timeout / auto-submit
  source String @default("student")

  // DEPRECATED / DEAD — superseded by the append-only exam log. Return state +
  // scoring now live in ExamAuditLog ('return' / 'take_back' events, frozen
  // snapshot in payload) and are derived via src/lib/scoring/return-state.ts; no
  // code reads these columns anymore. Kept temporarily so this change is pure
  // expand (the contract migration `drop_exam_submission_return_fields` drops them
  // AFTER this ships + is verified — see CLAUDE plan / backfill-return-events.mjs).
  score         Float?
  scoredBy      String?   @map("scored_by")
  scoredAt      DateTime? @map("scored_at")
  returnedAt    DateTime? @map("returned_at")
  gradeSnapshot Json?     @map("grade_snapshot")

  page    Page  @relation("ExamSubmissions", fields: [pageId], references: [id], onDelete: Cascade)
  student User  @relation("StudentExamSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  scorer  User? @relation("ScoredExamSubmissions", fields: [scoredBy], references: [id])

  @@unique([pageId, studentId])
  @@index([pageId])
  @@index([studentId])
  @@map("exam_submissions")
}

// Append-only event log of everything that happens to one student's exam, per
// page. Two families of events share this one timeline:
//   - Attempt lifecycle: "started" | "submitted" | "reopened". The roster pairs
//     starts with submits (and reopens) to show "took 43m" across attempts, even
//     after sessions/submissions are deleted on reopen.
//   - Grading: "return" | "take_back". This log is the SINGLE SOURCE OF TRUTH for
//     return state — there is no denormalized flag on ExamSubmission. A student is
//     "currently returned" iff their latest event in {return, take_back, reopened}
//     is a "return" (so a reopen naturally un-returns). Every "return" keeps its OWN
//     frozen snapshot in `payload` forever — re-returning APPENDS, never overwrites,
//     so the original return is preserved. See src/lib/scoring/return-state.ts.
// Readers that only want the attempt lifecycle (the roster) MUST filter by event;
// see src/app/api/exams/[pageId]/audit/route.ts.
model ExamAuditLog {
  id         String   @id @default(cuid())
  pageId     String   @map("page_id")
  studentId  String   @map("student_id")
  event      String // "started" | "submitted" | "reopened" | "return" | "take_back"
  occurredAt DateTime @default(now()) @map("occurred_at")

  // Set only on grading events (return / take_back); null on lifecycle events.
  payload   Json?   @map("payload") // "return": frozen buildReviewScores() snapshot. null otherwise.
  score     Float? // "return": aggregate points earned (mirrors payload.totalEarned).
  createdBy String? @map("created_by") // teacher actor for return/take_back; null for student/system events.

  page    Page  @relation("PageExamAuditLogs", fields: [pageId], references: [id], onDelete: Cascade)
  student User  @relation("StudentExamAuditLogs", fields: [studentId], references: [id], onDelete: Cascade)
  actor   User? @relation("ActorExamAuditLogs", fields: [createdBy], references: [id])

  @@index([pageId, studentId, occurredAt])
  @@index([pageId, occurredAt])
  @@index([pageId])
  @@map("exam_audit_logs")
}

// Grade key for an exam page (one row per page). The grade computation lives in
// src/lib/grading; this only stores the teacher-chosen parameters.
// formula="twoSegment": 4.0 lands exactly at passPercent (two linear segments).
// formula="linear": grade = 1 + 5*(points/max), passPercent ignored.
// maxPoints null = auto-sum of every gradable component's declared max.
model ExamGradeConfig {
  id           String   @id @default(cuid())
  pageId       String   @unique @map("page_id")
  maxPoints    Float?   @map("max_points")
  passPercent  Float    @default(60) @map("pass_percent")
  passGrade    Float    @default(4) @map("pass_grade")
  topGrade     Float    @default(6) @map("top_grade")
  bottomGrade  Float    @default(1) @map("bottom_grade")
  roundingStep Float    @default(0.1) @map("rounding_step")
  formula      String   @default("twoSegment") // "linear" | "twoSegment"
  updatedBy    String?  @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  page Page @relation("ExamGradeConfigs", fields: [pageId], references: [id], onDelete: Cascade)

  @@map("exam_grade_configs")
}

// NOTE: ExamQuestionGrade (override) and ExamCheckRun (check score) were
// collapsed into ComponentScore (below) — one priority-based score record per
// source. The backfill copied their rows in; the drop_legacy_score_tables
// migration removes the two old tables. See scripts/backfill-component-scores.mjs.

// One scoring verdict for one gradable component, from one source. Multiple
// sources can coexist per (page, student, component); the effective score is the
// highest-`priority` row with a non-null `earned` (feedback is resolved
// independently, also by highest priority; ties broken by most recent updatedAt).
// Generalizes the old `override ?? check` resolver to N sources. Replaces
// ExamCheckRun (source="check") and ExamQuestionGrade (source="override"); the
// backfill migration copies those in. A new scoring feature just inserts rows
// with a new `source` + chosen `priority` — no schema change.
// Seeded priorities: check=10, ai=20, override=100.
// `score`/`scoring` = points (Punkte); the 1-6 grade is computed only by the
// grade key (ExamGradeConfig), never stored here. See src/lib/scoring.
model ComponentScore {
  id          String @id @default(cuid())
  pageId      String @map("page_id")
  studentId   String @map("student_id")
  componentId String @map("component_id") // "quiz-<id>" | "python-check-<id>"

  source   String // "check" | "ai" | "override" | <future>
  priority Int // higher wins; seeded per source, stored per row so it is re-rankable
  // Nullable: a row may carry only feedback (e.g. an override row with a note but
  // no points change). The row is deleted when both `earned` and `feedback` are null.
  earned   Float?
  max      Float? // declared/snapshot max for this component
  feedback String? // per-source written note (AI rationale / teacher feedback)

  // Source-specific provenance. check: { passed, total }. ai: { model, rubricId,
  // criteria: [{ id, points, comment }] }. override: usually empty.
  meta      Json?
  createdBy String?  @map("created_by") // teacher userId; null = machine (check/ai)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page    Page @relation("ComponentScores", fields: [pageId], references: [id], onDelete: Cascade)
  student User @relation("StudentComponentScores", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([pageId, studentId, componentId, source])
  @@index([pageId, studentId])
  @@map("component_scores")
}

// Step-1 artifact of AI scoring: the point allocation for one gradable component.
// The AI proposes criteria from (question + reference solution + all submissions);
// the teacher edits or authors them. AI scoring (step 2) reads this + a student's
// submission and writes a ComponentScore(source="ai"). One rubric per component.
model ScoringRubric {
  id          String   @id @default(cuid())
  pageId      String   @map("page_id")
  componentId String   @map("component_id")
  criteria    Json // [{ id, description, points }]
  maxPoints   Float?   @map("max_points") // usually sum(criteria.points)
  source      String   @default("ai") // "ai" | "teacher"
  model       String? // model id when AI-generated
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  page Page @relation("ScoringRubrics", fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, componentId])
  @@map("scoring_rubrics")
}

// Per-teacher encryption keypair used to encrypt offline exam backups (.examfile).
// Students encrypt with the teacher's RSA-OAEP public key; teacher decrypts with
// the private key on the recovery endpoint. Rotatable: rotating flips isActive
// on the current row and inserts a new active one. Old rows are kept forever so
// historical backups remain decryptable. v1 stores the private key as a plain
// JWK; future versions should wrap it with a server master key at rest.
model TeacherExamKey {
  id            String    @id @default(cuid())
  teacherId     String    @map("teacher_id")
  keyId         String    @unique @map("key_id") // short embedded id (10 chars) referenced in .examfile
  publicKeyJwk  Json      @map("public_key_jwk")
  privateKeyJwk Json      @map("private_key_jwk") // v1: plain JWK. TODO: encrypt at rest.
  isActive      Boolean   @default(true) @map("is_active") // only one active row per teacher
  createdAt     DateTime  @default(now()) @map("created_at")
  rotatedAt     DateTime? @map("rotated_at") // null while active

  teacher User @relation("TeacherExamKeys", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, isActive])
  @@map("teacher_exam_keys")
}

// Cross-domain authentication tokens
// Used to transfer sessions from eduskript.org to custom domains
model CrossDomainToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  domain    String // Target custom domain
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // Null until token is consumed
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("cross_domain_tokens")
}

// Generic metrics system for tracking site-wide statistics
// Normalized: one row per metric per hour
// In-memory buffer handles minute-level data, flushed hourly to DB
model MetricPoint {
  id        String   @id @default(cuid())
  name      String // e.g., "db_queries_per_request", "page_load_time_ms"
  timestamp DateTime // Rounded to hour
  avg       Float // Average value for this hour
  count     Int // Number of samples (for weighted aggregation)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, timestamp])
  @@index([name, timestamp])
  @@index([timestamp])
  @@map("metric_points")
}

// Subscription plans available for purchase
model Plan {
  id             String   @id @default(cuid())
  name           String // e.g., "Basic", "Pro"
  slug           String   @unique // URL-safe identifier, e.g., "pro-monthly"
  priceChf       Int // Price in Rappen (cents), e.g., 990 = CHF 9.90
  interval       String // "monthly" | "yearly"
  features       Json // Feature flags, e.g., { maxSkripts: 50, customDomain: true }
  isActive       Boolean  @default(true) @map("is_active") // Soft-delete for retired plans
  trialDays      Int?     @map("trial_days") // null = no trial for this plan
  isDefaultTrial Boolean  @default(false) @map("is_default_trial") // Only one plan should have this set
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

// User subscriptions managed via Payrexx
model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  planId             String    @map("plan_id")
  payrexxSubId       String?   @unique @map("payrexx_sub_id") // Payrexx subscription ID
  payrexxCustomerId  String?   @map("payrexx_customer_id") // Payrexx customer/contact ID
  status             String    @default("incomplete") // "active" | "cancelled" | "past_due" | "trialing" | "incomplete"
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelledAt        DateTime? @map("cancelled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([payrexxSubId])
  @@map("subscriptions")
}

/// Teacher-created plugins rendered in sandboxed iframes within markdown content.
/// All plugins are globally visible — teachers reference them as ownerPageSlug/pluginSlug.
model Plugin {
  id          String   @id @default(cuid())
  slug        String // Plugin slug (unique per author)
  name        String // Display name
  description String?  @db.Text
  version     String   @default("1.0.0")
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  manifest    Json // configSchema, defaultHeight, allowedCDNs, etc.
  entryHtml   String   @db.Text // Self-contained HTML (rendered in sandboxed iframe)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([authorId, slug])
  @@index([authorId])
  @@map("plugins")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Start from scratch? 
// pnpm prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql
// pnpm prisma migrate resolve --applied 0_init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?    // Microsoft-specific: extended token expiration
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model User {
  id          String    @id @default(cuid())
  name        String?
  email       String?   @unique // Optional for students (OAuth-only)
  emailVerified DateTime?
  image       String?
  hashedPassword String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Webpage-specific fields
  username      String?   @unique // Public username for URL paths (e.g., eduskript.org/username)
  webpageDescription String? // Description of their webpage
  bio           String?
  title         String?

  // User preferences
  themePreference String? @default("system") // "light", "dark", or "system"
  sidebarBehavior String? @default("contextual") // "contextual" (default - show only current collection) or "full" (always show all)
  typographyPreference String? @default("modern") // "modern" (Roboto Slab + Barlow Condensed) or "classic" (EB Garamond + Barlow Condensed)

  // Admin and security
  isAdmin Boolean @default(false)
  requirePasswordReset Boolean @default(false)

  // Privacy and account type
  accountType      String    @default("teacher") // "teacher" or "student"
  studentPseudonym String?   @unique // For student privacy: hash(oauthProvider:oauthProviderId) for OAuth, hash(email) for legacy
  gdprConsentAt    DateTime? // Timestamp of GDPR consent acceptance
  lastSeenAt       DateTime? // For inactive account cleanup

  // OAuth identification (for students - replaces email storage)
  oauthProvider    String?   // "github", "google", "microsoft", "azure-ad"
  oauthProviderId  String?   // Provider's unique user ID

  // Relations
  accounts      Account[]
  sessions      Session[]
  pageVersions  PageVersion[]
  
  // Many-to-many relations for authoring
  collectionAuthors   CollectionAuthor[]
  skriptAuthors SkriptAuthor[]
  pageAuthors    PageAuthor[]
  
  // Collection-skript relationships (for root-level placements)
  collectionSkripts   CollectionSkript[]
  
  // File uploads
  files          File[]
  
  // Collaboration relations
  sentCollaborationRequests     CollaborationRequest[] @relation("SentRequests")
  receivedCollaborationRequests CollaborationRequest[] @relation("ReceivedRequests")
  collaborationsAsRequester     Collaboration[] @relation("RequesterCollaborations")
  collaborationsAsReceiver      Collaboration[] @relation("ReceiverCollaborations")
  
  // Page layout
  pageLayout PageLayout?

  // Student data
  studentProgress    StudentProgress[]   @relation("StudentProgress")
  studentSubmissions StudentSubmission[] @relation("StudentSubmissions")

  // Class relations
  teacherClasses     Class[]             @relation("TeacherClasses")
  studentMemberships ClassMembership[]   @relation("StudentMemberships")

  // Identity reveal requests (deprecated - will be removed)
  teacherIdentityRequests IdentityRevealRequest[] @relation("TeacherIdentityRequests")
  studentIdentityRequests IdentityRevealRequest[] @relation("StudentIdentityRequests")

  // User data (code, annotations, settings, etc.)
  userData UserData[] @relation("UserDataEntries")

  // Front page
  frontPage         FrontPage?
  frontPageVersions FrontPageVersion[]

  // Import/Export jobs
  importJobs ImportJob[]

  @@unique([oauthProvider, oauthProviderId]) // Students identified by OAuth provider
  @@map("users")
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  collectionSkripts CollectionSkript[]
  
  // Many-to-many relation for multiple authors
  authors     CollectionAuthor[]
  
  @@map("collections")
}

// Junction table for Collection-User many-to-many relationship
model CollectionAuthor {
  id           String   @id @default(cuid())
  collectionId String
  userId       String
  permission   String   @default("author") // "author" (can edit & manage), "viewer" (can only view)
  createdAt    DateTime @default(now())
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([collectionId, userId])
  @@map("collection_authors")
}

// Junction table for Collection-Skript many-to-many relationship
model CollectionSkript {
  id           String   @id @default(cuid())
  collectionId String?  // Nullable - null means root level
  skriptId     String
  userId       String?  // ONLY used for root level items (when collectionId is null)
  order        Int      // Order within the collection or root level
  createdAt    DateTime @default(now())
  
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  skript       Skript      @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([collectionId, skriptId]) // One entry per skript per collection
  @@unique([skriptId, userId]) // One root entry per skript per user (when collectionId is null)
  @@map("collection_skripts")
}

model Skript {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  collectionSkripts CollectionSkript[]
  pages            Page[]

  // Many-to-many relation for multiple authors
  authors     SkriptAuthor[]

  // Files associated with this skript
  files       File[]

  // Front page (intro/landing page for skript)
  frontPage   FrontPage?

  @@map("skripts")
}

// Junction table for Skript-User many-to-many relationship
model SkriptAuthor {
  id        String   @id @default(cuid())
  skriptId  String
  userId    String
  permission String  @default("author") // "author" (can edit & manage), "viewer" (can only view)
  createdAt DateTime @default(now())
  
  skript    Skript   @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([skriptId, userId])
  @@map("skript_authors")
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String
  order       Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  skriptId    String
  skript      Skript   @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  versions    PageVersion[]

  // Many-to-many relation for multiple authors
  authors     PageAuthor[]

  // Student data
  studentProgress    StudentProgress[]   @relation("PageProgress")
  studentSubmissions StudentSubmission[] @relation("PageSubmissions")

  @@unique([skriptId, slug])
  @@map("pages")
}

// Junction table for Page-User many-to-many relationship
model PageAuthor {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  permission String  @default("author") // "author" (can edit & manage), "viewer" (can only view)
  createdAt DateTime @default(now())
  
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([pageId, userId])
  @@map("page_authors")
}

model PageVersion {
  id        String   @id @default(cuid())
  content   String
  version   Int
  changeLog String?
  authorId  String
  pageId    String
  createdAt DateTime @default(now())
  
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  page   Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  @@unique([pageId, version])
  @@map("page_versions")
}

model File {
  id          String  @id @default(cuid())
  name        String
  parentId    String? @map("parent_id")
  isDirectory Boolean @default(false) @map("is_directory")
  skriptId    String  @map("skript_id")
  hash        String?
  contentType String? @map("content_type")
  size        BigInt?
  createdBy   String  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  parent   File?    @relation("FileParent", fields: [parentId], references: [id], onDelete: Cascade)
  children File[]   @relation("FileParent")
  skript   Skript   @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([parentId, name, skriptId], name: "unique_file_name_per_parent_skript")
  @@index([parentId, skriptId], name: "parent_skript_idx")
  @@index([hash], name: "hash_idx")
  @@map("files")
}

// Collaboration request model for pending requests
model CollaborationRequest {
  id          String   @id @default(cuid())
  requesterId String   @map("requester_id")
  receiverId  String   @map("receiver_id")
  message     String?  // Optional message from requester
  status      String   @default("pending") // "pending", "accepted", "rejected"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@map("collaboration_requests")
}

// Collaboration model for accepted partnerships
model Collaboration {
  id          String   @id @default(cuid())
  requesterId String   @map("requester_id")  // User who sent the original request
  receiverId  String   @map("receiver_id")   // User who accepted the request
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  requester User @relation("RequesterCollaborations", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceiverCollaborations", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@map("collaborations")
}

// Page layout for user's public page
model PageLayout {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  items     PageLayoutItem[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("page_layouts")
}

// Individual items in a page layout
model PageLayoutItem {
  id           String @id @default(cuid())
  pageLayoutId String @map("page_layout_id")
  type         String // "collection" or "skript"
  contentId    String @map("content_id") // ID of the collection or skript
  order        Int
  createdAt    DateTime @default(now()) @map("created_at")

  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@unique([pageLayoutId, contentId, type])
  @@map("page_layout_items")
}

// Student Progress Tracking
// Tracks which pages students have viewed and completed
model StudentProgress {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  pageId       String   @map("page_id")
  completed    Boolean  @default(false)
  lastViewedAt DateTime @default(now()) @map("last_viewed_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student User @relation("StudentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  page    Page @relation("PageProgress", fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([studentId, pageId])
  @@index([studentId])
  @@index([pageId])
  @@map("student_progress")
}

// Student Submissions
// Stores student work like annotations, code, or text submissions
model StudentSubmission {
  id          String   @id @default(cuid())
  studentId   String   @map("student_id")
  pageId      String   @map("page_id")
  contentData String   @map("content_data") // JSON stringified data (annotations, code, etc.)
  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  grade       Float?   // Optional numeric grade
  feedback    String?  // Optional teacher feedback

  student User @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  page    Page @relation("PageSubmissions", fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([studentId, pageId])
  @@index([studentId])
  @@index([pageId])
  @@map("student_submissions")
}

// Class model - teacher-owned groups of students
model Class {
  id          String   @id @default(cuid())
  name        String
  description String?
  teacherId   String   @map("teacher_id")
  inviteCode  String   @unique @map("invite_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  teacher               User                      @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  memberships           ClassMembership[]
  preAuthorizedStudents PreAuthorizedStudent[]
  identityRevealRequests IdentityRevealRequest[]

  @@index([teacherId])
  @@index([inviteCode])
  @@map("classes")
}

// Junction table for Class-Student many-to-many
model ClassMembership {
  id              String    @id @default(cuid())
  classId         String    @map("class_id")
  studentId       String    @map("student_id")
  joinedAt        DateTime  @default(now()) @map("joined_at")

  // Privacy: Student consent for teacher to see their real identity
  identityConsent Boolean   @default(false) @map("identity_consent")
  consentedAt     DateTime? @map("consented_at")

  // Relations
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("StudentMemberships", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@map("class_memberships")
}

// Pre-authorized student pseudonyms (for bulk import)
model PreAuthorizedStudent {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  pseudonym String   // Hashed email (before student signs up)
  addedAt   DateTime @default(now()) @map("added_at")

  // Relations
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, pseudonym])
  @@index([pseudonym])
  @@index([classId])
  @@map("pre_authorized_students")
}

// DEPRECATED - Identity reveal requests
// This model will be removed in favor of ClassMembership.identityConsent
// Keeping temporarily for migration purposes
model IdentityRevealRequest {
  id         String   @id @default(cuid())
  classId    String   @map("class_id")
  teacherId  String   @map("teacher_id")
  studentId  String   @map("student_id") // The actual student user ID
  email      String   // PRIVACY ISSUE: Email stored on server - being removed
  status     String   @default("pending") // "pending", "approved", "rejected"
  requestedAt DateTime @default(now()) @map("requested_at")
  respondedAt DateTime? @map("responded_at")

  // Relations
  class    Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher  User  @relation("TeacherIdentityRequests", fields: [teacherId], references: [id], onDelete: Cascade)
  student  User  @relation("StudentIdentityRequests", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId, email]) // One request per class-student-email combo
  @@index([studentId, status]) // Fast lookup for student's pending requests
  @@index([classId])
  @@index([teacherId])
  @@map("identity_reveal_requests")
}

// User Data Storage
// Stores all user-generated data (code, annotations, settings) with cloud sync support
// Uses JSONB for flexible, queryable storage with efficient updates
model UserData {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  adapter   String   // Data type: 'code', 'annotations', 'settings', 'preferences', 'snaps'
  itemId    String   @map("item_id") // pageId for page-specific data, 'global' for user-wide data
  data      Json     // JSONB - the actual data payload
  version   Int      @default(1) // Optimistic concurrency control
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation("UserDataEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, adapter, itemId])
  @@index([userId])
  @@index([userId, adapter])
  @@index([updatedAt])
  @@map("user_data")
}

// FrontPage model - custom landing pages for users and skripts
// Supports versioning and draft mode (isPublished)
model FrontPage {
  id          String   @id @default(cuid())
  content     String   @default("")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Owner - exactly one of these should be set
  userId      String?  @unique @map("user_id")    // For user landing pages
  skriptId    String?  @unique @map("skript_id")  // For skript intro pages

  // Relations
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skript   Skript?  @relation(fields: [skriptId], references: [id], onDelete: Cascade)
  versions FrontPageVersion[]

  @@map("front_pages")
}

// Version history for front pages
model FrontPageVersion {
  id          String   @id @default(cuid())
  content     String
  version     Int
  changeLog   String?  @map("change_log")
  authorId    String   @map("author_id")
  frontPageId String   @map("front_page_id")
  createdAt   DateTime @default(now()) @map("created_at")

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  frontPage FrontPage @relation(fields: [frontPageId], references: [id], onDelete: Cascade)

  @@unique([frontPageId, version])
  @@map("front_page_versions")
}

// Import/Export Job Tracking
// Tracks large file import/export operations with progress and one-per-user limit
model ImportJob {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // "import" or "export"
  status      String   @default("pending") // "pending", "uploading", "processing", "completed", "failed", "cancelled"
  progress    Int      @default(0) // 0-100
  message     String?  // Current status message for UI

  // File info
  s3Key       String?  @map("s3_key") // S3 key for uploaded/exported file
  fileName    String?  @map("file_name") // Original filename
  fileSize    BigInt?  @map("file_size") // Size in bytes

  // Results
  result      Json?    // Import: { skriptsCreated, pagesCreated, filesImported }, Export: { downloadUrl }
  error       String?  // Error message if failed

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@map("import_jobs")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Start from scratch? 
// pnpm prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql
// pnpm prisma migrate resolve --applied 0_init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model User {
  id          String    @id @default(cuid())
  name        String?
  email       String    @unique
  emailVerified DateTime?
  image       String?
  hashedPassword String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Webpage-specific fields
  subdomain     String?   @unique
  webpageDescription String? // Description of their webpage
  bio           String?
  title         String?
  
  // User preferences
  themePreference String? @default("system") // "light", "dark", or "system"
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  customDomains CustomDomain[]
  pageVersions  PageVersion[]
  
  // Many-to-many relations for authoring
  topicAuthors   TopicAuthor[]
  chapterAuthors ChapterAuthor[]
  pageAuthors    PageAuthor[]
  
  // File uploads
  files          File[]
  
  @@map("users")
}

model CustomDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  userId    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("custom_domains")
}

model Topic {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  chapters    Chapter[]
  
  // Many-to-many relation for multiple authors
  authors     TopicAuthor[]
  
  @@map("topics")
}

// Junction table for Topic-User many-to-many relationship
model TopicAuthor {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  role      String   @default("author") // "author", "editor", "reviewer", etc.
  createdAt DateTime @default(now())
  
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([topicId, userId])
  @@map("topic_authors")
}

model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String
  order       Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  pages       Page[]
  
  // Many-to-many relation for multiple authors
  authors     ChapterAuthor[]
  
  // Files associated with this chapter
  files       File[]
  
  @@unique([topicId, slug])
  @@map("chapters")
}

// Junction table for Chapter-User many-to-many relationship
model ChapterAuthor {
  id        String   @id @default(cuid())
  chapterId String
  userId    String
  role      String   @default("author") // "author", "editor", "reviewer", etc.
  createdAt DateTime @default(now())
  
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([chapterId, userId])
  @@map("chapter_authors")
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String
  order       Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  versions    PageVersion[]
  
  // Many-to-many relation for multiple authors
  authors     PageAuthor[]
  
  @@unique([chapterId, slug])
  @@map("pages")
}

// Junction table for Page-User many-to-many relationship
model PageAuthor {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  role      String   @default("author") // "author", "editor", "reviewer", etc.
  createdAt DateTime @default(now())
  
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([pageId, userId])
  @@map("page_authors")
}

model PageVersion {
  id        String   @id @default(cuid())
  content   String
  version   Int
  changeLog String?
  authorId  String
  pageId    String
  createdAt DateTime @default(now())
  
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  page   Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  @@unique([pageId, version])
  @@map("page_versions")
}

model File {
  id          String  @id @default(cuid())
  name        String
  parentId    String? @map("parent_id")
  isDirectory Boolean @default(false) @map("is_directory")
  chapterId   String  @map("chapter_id")
  hash        String? @unique
  contentType String? @map("content_type")
  size        BigInt?
  createdBy   String  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  parent   File?    @relation("FileParent", fields: [parentId], references: [id], onDelete: Cascade)
  children File[]   @relation("FileParent")
  chapter  Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([parentId, name, chapterId], name: "unique_file_name_per_parent_chapter")
  @@index([parentId, chapterId], name: "parent_chapter_idx")
  @@index([hash], name: "hash_idx")
  @@map("files")
}

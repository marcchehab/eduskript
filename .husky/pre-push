echo "🔍 Running pre-push validation..."
echo ""

# Regenerate Prisma client so type-check sees the live schema (stale clients
# after schema edits have blocked pushes before).
echo "🗄️  Generating Prisma client..."
pnpm db:generate || exit 1
echo "✅ Prisma client up to date"
echo ""

# Run type checking
echo "📘 Type checking..."
pnpm type-check || exit 1
echo "✅ Types valid"
echo ""

# Run linting
echo "🧹 Linting..."
pnpm lint || exit 1
echo "✅ Lint passed"
echo ""

# Run tests
echo "🧪 Running tests..."
pnpm test:run || exit 1
echo "✅ Tests passed"
echo ""

echo "🎉 All checks passed! Pushing..."

# Detached, self-terminating watcher: fires a desktop notification when the Koyeb
# deploy this push triggers settles HEALTHY or fails. `timeout 20m` is a hard outer
# cap so a hung CLI call can never leave it running; setsid -f fully detaches it so
# the push returns immediately. No-ops silently without koyeb/jq/notify-send.
setsid -f timeout 20m "$(dirname "$0")/../scripts/koyeb-deploy-watch.sh" >/dev/null 2>&1 || true

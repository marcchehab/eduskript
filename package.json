{
  "name": "eduskript",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup-dev.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "dev": "next dev --turbopack",
    "dev:tunnel": "next dev --turbopack & sleep 3 && ngrok http http://localhost:3000",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://dummy:dummy@localhost:5432/dummy} prisma generate && next build --webpack && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "docs:sync": "npx tsx scripts/sync-docs.ts",
    "start": "prisma migrate deploy && (node scripts/seed-admin.js || echo 'Seeding failed, continuing...') && (node scripts/sync-docs.mjs || echo 'Docs sync failed, continuing...') && node .next/standalone/server.js",
    "lint": "eslint . --max-warnings=-1",
    "type-check": "tsc --noEmit",
    "validate": "pnpm type-check && pnpm lint && pnpm test:run",
    "pre-push": "pnpm type-check && pnpm lint && pnpm test:run && pnpm build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy && node scripts/seed-admin.js",
    "devdb:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && node scripts/seed-admin.js",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:local": "docker compose -f docker-compose.local.yml up -d",
    "db:local:stop": "docker compose -f docker-compose.local.yml down",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "engines": {
    "node": "22.x"
  },

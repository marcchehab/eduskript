{
  "name": "eduskript",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup-dev.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "update": "git pull && pnpm install && pnpm db:generate",
    "deps:check": "bash scripts/deps-check.sh",
    "dev": "next dev --turbopack",
    "dev:tunnel": "ngrok http http://localhost:3000",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://dummy:dummy@localhost:5432/dummy} prisma generate && next build --webpack && rm -rf .next/standalone/public .next/standalone/.next/static && cp -rT .next/static .next/standalone/.next/static && cp -rT public .next/standalone/public",
    "docs:sync": "npx tsx scripts/sync-docs.ts",
    "ai:ranking:update": "node scripts/rank-ai-models.mjs --html",
    "ai:probe": "node scripts/probe-ai-latency.mjs",
    "start": "prisma migrate deploy && (node scripts/seed-admin.js || echo 'Seeding failed, continuing...') && (node scripts/seed-demo.mjs || echo 'Demo seed failed, continuing...') && (node scripts/sync-docs.mjs || echo 'Docs sync failed, continuing...') && (node scripts/seed-plugins.mjs || echo 'Plugin seed failed, continuing...') && node .next/standalone/server.js",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "validate": "pnpm type-check && pnpm lint && pnpm test:run",
    "pre-push": "pnpm db:generate && pnpm type-check && pnpm lint && pnpm test:run",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:seed": "node scripts/seed-e2e.mjs",
    "test:e2e": "node scripts/seed-e2e.mjs && playwright test",
    "test:e2e:ui": "node scripts/seed-e2e.mjs && playwright test --ui",
    "test:e2e:watch": "node scripts/seed-e2e.mjs && E2E_HEADED=1 E2E_SLOMO=350 playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy && node scripts/seed-admin.js",
    "db:local:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && node scripts/seed-admin.js",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:local": "docker compose -f docker-compose.local.yml up -d",
    "db:local:stop": "docker compose -f docker-compose.local.yml down",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "engines": {
    "node": "22.x"
  },
